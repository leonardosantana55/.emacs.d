  \"Delete 4 spaces to the left of the cursor if they exist, otherwise delete normally.\"
  (interactive)
  (let ((column (current-column)))
    (if (and (>= column 4)
             (string= (buffer-substring-no-properties (- (point) 4) (point)) \"    \"))
        (delete-char -4)
      (delete-char -1))))

;; Bind it to your Backspace key
